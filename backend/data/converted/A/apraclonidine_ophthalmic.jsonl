  "effects_and_mechanisms": {
    "common_mechanism": "비교적 선택적인 알파-2 아드레날린 수용체 작용제. 시냅스 전 알파-2 수용체 활성화로 노르에피네프린 분비 억제, 시냅스 후 알파-2 수용체 활성화로 섬모체 비색소 상피세포 내 cAMP 감소 → 방수 생성 감소 및 안압 하강. 포도막공막 유출 증가 및 기존 유출로 저항 감소 효과도 있음.",
    "common_extra_effects": [
      "결막 창백(conjunctival blanching)",
      "안검 거상(eyelid elevation)",
      "산동(mydriasis)",
      "구강 건조",
      "안구 건조",
      "빈맥",
      "고혈압",
      "빈호흡",
      "장기 사용 시 빠른 내성(tachyphylaxis)"
    ],
    "dog_mechanism": "알파-2 작용제로 방수 생성 억제 및 안압 감소. 도르졸아미드/티몰롤과 병용 시 안압 조절 효과 보고.",
    "dog_extra_effects": [
      "구토",
      "설사"
    ],
    "cat_mechanism": "알파-2 작용제. 고양이에서 전신 흡수로 인한 심각한 부작용 발생 가능.",
    "cat_extra_effects": [
      "서맥(bradycardia)",
      "과다침분비(hypersalivation)",
      "설사",
      "구토"
    ]
  },
  "species_notes": {
    "dog": "개에서 오프라벨로 사용 가능하며, 다른 녹내장 치료제로 최대 치료 중에도 안압이 추가 조절이 필요한 경우 단기 보조 요법으로 고려할 수 있음. 도르졸아미드/티몰롤 병용 시 약 8개월간 안압 조절 성공 사례가 보고됨. 장기 사용 시 빠른 내성(tachyphylaxis) 발생에 주의. 구토 및 설사가 발생할 수 있음.",
    "cat": "고양이에서는 서맥, 과다침분비, 설사, 구토 등의 심각한 전신 부작용이 보고되어 사용이 금기임. 절대 사용하지 말 것."
  },
