  "effects_and_mechanisms": {
    "common_mechanism": "티오프로닌은 티올-이황화물 교환 반응을 통해 시스틴(시스테인-시스테인 이황화물)과 반응하여 수용성이 높은 티오프로닌-시스틴 이황화물 복합체를 형성함으로써 시스틴 결석 형성을 억제하는 킬레이트제.",
    "common_extra_effects": [
      "단백뇨",
      "혈소판감소증",
      "Coombs 양성 재생성 구상적혈구 빈혈",
      "간효소 상승",
      "피부 이상반응 (소농포, 건조한 딱지 코)",
      "기면",
      "공격적 행동",
      "소변의 황 냄새",
      "근병증 (비틀거림, 씹기 어려움)"
    ],
    "dog_mechanism": "시스틴과 티올-이황화물 교환 반응을 통해 수용성 복합체를 형성하여 시스틴 결석 형성 억제. 효과는 용량 의존적이며 치료 첫날부터 나타남.",
