  "effects_and_mechanisms": {
    "common_mechanism": "코르티손 아세테이트는 체내에서 코르티솔(하이드로코르티손)로 전환되어 글루코코르티코이드 및 미네랄코르티코이드 수용체에 작용. 포유류의 거의 모든 세포 유형 및 시스템에 영향을 미침.",
    "common_extra_effects": [
      "식욕 증가",
      "다음다뇨",
      "위장관 장애 (구토, 식욕부진, 설사)",
      "과민반응",
      "저칼륨혈증",
      "고혈당",
      "호중구증가증",
      "림프구감소증",
      "체중 증가",
      "수분 저류"
    ],
    "dog_mechanism": "생리적 대체 용량에서는 일반적으로 내약성이 좋음. 초생리적 용량에서는 프레드니솔론과 유사한 부작용 프로파일 가능.",
    "dog_extra_effects": [
      "위장관 궤양, 천공, 출혈 (초생리적 용량)",
      "의인성 쿠싱 증후군 (장기 고용량 사용 시)",
      "림프구감소증 (약물 중단 후 수 주간 지속 가능)"
    ],
    "cat_mechanism": null,
    "cat_extra_effects": []
  },
  "species_notes": {
    "dog": "개의 부신피질기능저하증 치료에 프레드니솔론의 대안으로 사용 가능. 코르티손의 증가된 미네랄코르티코이드 활성이 임상적으로 유의미한지는 논란이 있으며, 일부 전문가는 프레드니솔론을 선호함. 통상 플루드로코르티손과 병용. ACTH 자극 검사는 코르티손 투여 전에 실시해야 함(교차반응 있음).",
    "cat": "고양이에 대한 용량 정보 및 임상 데이터가 본 모노그래프에 없음. 고양이에서의 사용은 권장되지 않거나 데이터 부족으로 평가 불가."
  },
  "precautions": {
    "dog": {
      "status": 1,
      "evidence": "생리적 대체 용량에서는 일반적으로 내약성 양호. 초생리적 용량 사용 시 프레드니솔론과 동일한 주의사항 적용. 당뇨병, 위장관 궤양, 감염, 임신 시 주의 필요."
    },
    "cat": {
      "status": 1,
      "evidence": "고양이에 대한 특이적 안전성 데이터 없음. 사용 시 주의 요망."
    }
  },
  "storage_and_forms": {
    "storage": "밀폐 용기에 40°C(104°F) 미만, 가급적 15°C~30°C(59°F~86°F)에서 보관.",
    "forms": [
      "코르티손 아세테이트 경구 정제 25mg (인체용, 제네릭, 처방전 필요)"
    ]
  },
  "section_1_2_10": {
    "highlights": "코르티손은 글루코코르티코이드 및 미네랄코르티코이드 효과를 모두 가진 단기 작용 코르티코스테로이드로, 개의 부신피질기능저하증 치료에 프레드니솔론의 대안으로 사용될 수 있습니다. 수의학에서 허가된 제품은 없으며 오프라벨 사용입니다. 생리적 대체 용량에서는 내약성이 좋으나, 초생리적 용량 사용 시 일반 코르티코스테로이드 부작용 프로파일이 적용됩니다. ACTH 자극 검사와 교차반응이 있으므로 투여 전 검사를 완료해야 합니다.",
    "indications": "개의 부신피질기능저하증(애디슨병) 장기 치료 (오프라벨). 플루드로코르티손과 병용하여 글루코코르티코이드 보충 목적으로 사용. 코르티손 아세테이트는 체내에서 코르티솔로 전환되어 글루코코르티코이드 및 미네랄코르티코이드 결핍 모두에 대한 완전 대체 요법으로 기능할 수 있음.",
