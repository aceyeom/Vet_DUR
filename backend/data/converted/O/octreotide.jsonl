  "effects_and_mechanisms": {
    "common_mechanism": "소마토스타틴의 합성 장기작용 유사체로, 인슐린, 글루카곤, 세크레틴, 성장호르몬, 가스트린, 모틸린의 합성 및 분비를 억제함. 소마토스타틴 수용체(SSTR) 아형에 결합하며, 특히 SSTR2에 우선적으로 결합함.",
    "common_extra_effects": [
      "서맥(Bradycardia)",
      "갑상선기능저하증(Hypothyroidism)",
      "오심(Nausea)",
      "설사(Diarrhea)",
      "복부 불편감(Abdominal discomfort)",
      "담석(Gallstones)",
      "담즙 슬러지(Biliary sludge)",
      "담도 확장(Biliary tract dilatation)",
      "저혈당(Hypoglycemia)",
      "고혈당(Hyperglycemia)",
      "주사 부위 불편감 및 반응(Injection site discomfort/reactions)",
      "췌장염(Pancreatitis, 인간)",
      "비타민 B12 감소(Decreased vitamin B12, 인간)",
      "지방 흡수 감소(Reduced fat absorption)"
    ],
    "dog_mechanism": "개는 SSTR2 아형만 보유함. 인슐린종 세포 수용체가 옥트레오타이드에 높은 친화성을 가질 수 있음. 혈당 상승 효과는 일시적으로 3~4시간 지속될 수 있음.",
    "dog_extra_effects": [
      "식욕부진/거식증(Anorexia)",
      "일시적 혈당 상승 효과(Transient glycemic effect, 3~4시간)"
    ],
    "cat_mechanism": "말단비대증 고양이는 SSTR1 및 SSTR5 아형을 과발현하며, SSTR2 발현이 부족하여 옥트레오타이드에 반응하지 않을 수 있음.",
    "cat_extra_effects": [
      "말단비대증에서 성장호르몬 감소 효과 없음(No effect on GH in acromegaly)"
    ]
  },
  "species_notes": {
    "dog": "개에서 인슐린종 치료 시 혈당 유지를 위해 하루 2~3회 주사가 필요함. 혈당 상승 효과는 일시적(3~4시간)이며, 장기 치료 시 내성이 발생할 수 있음. 종양 세포의 소마토스타틴 수용체 발현 여부에 따라 반응이 다를 수 있음. 아마톡신 버섯 중독 치료에도 사용 보고됨.",
    "cat": "고양이 말단비대증에는 SSTR2 발현 부족으로 효과가 없음. 유미흉 및 가스트린종 치료에 오프라벨로 사용 가능. 제한된 증례 수로 경험이 부족하므로 실험적 치료로 간주해야 함."
  },
  "precautions": {
    "dog": {
      "status": 1,
      "evidence": "담도계 질환 환자에서 주의 사용. 중증 신/간기능 장애 시 용량 조절 필요. 인슐린종 치료 시 혈당 모니터링 필수. 장기 치료 시 내성 발생 가능."
