  "effects_and_mechanisms": {
    "common_mechanism": "정확한 작용 기전은 불명확하나, 육아종성 염증 과정에 영향을 미치는 것으로 추정됨. 시험관 내 항균 활성은 거의 없음. 갑상선으로의 요오드 운반 및 갑상선 기능 조절에 관여.",
    "common_extra_effects": [
      "이오디즘 (과도한 눈물, 구토, 식욕부진, 비루, 근육 경련, 심근병증, 비늘성 피모/비듬, 고열, 기침, 설사)",
      "구역 및 구토",
      "불쾌한 맛으로 인한 투약 거부",
      "갑상선 기능 이상",
      "고칼륨혈증 (포타슘 요오드화물)"
    ],
    "dog_mechanism": null,
