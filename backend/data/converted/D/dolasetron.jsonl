  "effects_and_mechanisms": {
    "common_mechanism": "5-HT3(5-하이드록시트립타민3) 수용체를 선택적으로 차단하여 항구토 효과를 나타냄. CNS 화학수용체 유발대, 미주신경 말단, 장신경계의 5-HT3 수용체에 작용함.",
    "common_extra_effects": [
      "용량 의존적 ECG 변화 (PR, QT 간격 연장, QRS 확장)",
      "두통 (인간)",
      "어지러움 (인간)",
      "식욕 증가 (인간)"
    ],
    "dog_mechanism": "돌라세트론은 IV 투여 후 카르보닐 환원효소에 의해 빠르게 하이드로돌라세트론으로 전환되며, 이 활성 대사체가 5-HT3 수용체를 차단하여 항구토 효과를 나타냄.",
    "dog_extra_effects": [
      "ECG 변화 가능성",
      "위험 환자에서 심전도 모니터링 필요"
    ],
    "cat_mechanism": "개와 동일한 기전으로 추정되나 고양이 특이 데이터 부족. 자일라진 유발 구토에는 효과 없음.",
    "cat_extra_effects": [
      "자일라진 유발 구토 예방 효과 없음",
      "경구 투여 시 조제 필요 (정제 용량이 너무 큼)"
    ]
  },
  "species_notes": {
    "dog": "개에서 하이드로돌라세트론의 반감기는 약 4시간으로 1일 1회 투여가 가능하며, 화학요법 유발 구토 예방에 유용하다. 경구 생체이용률이 7%로 낮으나 임상적으로 효과적인 것으로 보고됨. 심장 위험 환자에서는 ECG 모니터링이 권장됨.",
    "cat": "고양이에서 상업용 정제(50 mg, 100 mg)는 용량이 너무 커서 직접 투여가 불가능하므로 반드시 조제(예: 10 mg/mL 경구 현탁액)가 필요하다. 자일라진 유발 구토에는 효과가 없는 것으로 확인됨. 화학요법 유발 구토에 오프라벨로 사용 가능."
  },
