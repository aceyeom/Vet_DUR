  "effects_and_mechanisms": {
    "common_mechanism": "섬모체 상피의 베타-1 수용체 차단을 통해 방수 생성을 감소시켜 안압(IOP)을 낮춤. cAMP 활성화 감소, Na+K+ATPase 억제, 홍채 및 섬모체의 혈관 작용 기전이 관여함. 또한 글루타민 유발 세포내 칼슘 및 나트륨 증가를 억제하여 망막 허혈 손상에 대한 보호 효과 가능.",
    "common_extra_effects": [
      "점안 시 일시적 작열감, 따끔거림, 자극",
      "각막염(keratitis)",
      "동공 크기 불균등(anisocoria)",
      "광선 공포증(photophobia)",
      "서맥(bradycardia)",
      "심장 차단(heart block)",
      "울혈성 심부전(congestive heart failure)",
      "호흡 곤란(pulmonary distress)",
      "불면증(insomnia)",
      "어지러움(dizziness)",
      "두통(headache)",
      "기면(lethargy)",
      "우울(depression)"
    ],
    "dog_mechanism": "개에서 편측성 녹내장 환자의 정상안에 대한 녹내장 발생 지연 효과가 보고됨. 0.5% 용액이 0.25% 용액보다 안압 감소 효과가 크나 이상반응 위험도 증가함.",
    "dog_extra_effects": [],
    "cat_mechanism": "다른 국소 베타차단제가 건강한 고양이에서 심박수를 유의하게 감소시킨다는 보고가 있어 주의 필요.",
    "cat_extra_effects": [
      "심박수 감소(heart rate reduction)"
    ]
  },
  "species_notes": {
    "dog": "개에서 편측성 녹내장 환자의 정상안에 녹내장 발생을 지연시키는 효과가 보고됨. 타플루프로스트와 병용 시 티몰롤 단독 사용보다 정상 개에서 안압 감소 효과가 더 큼. 0.5% 용액이 0.25% 용액보다 안압 감소 효과가 크나 이상반응 위험도 증가하므로 농도 선택 시 주의 필요.",
    "cat": "고양이에서 다른 국소 베타차단제가 심박수를 유의하게 감소시킨다는 보고가 있으므로, 베탁솔롤 점안 시에도 심혈관계 모니터링이 권장됨. 천식이 있는 고양이에서는 기관지 경련 유발 가능성에 주의해야 함."
  },
  "precautions": {
    "dog": {
      "status": 1,
      "evidence": "심장 차단, 서맥, 심부전, 천식, 만성 기관지염 환자에서 주의 사용. 당뇨병 환자에서 저혈당 증상을 가릴 수 있음. 갑상선 기능 항진증 환자에서 증상을 가릴 수 있음. 베타차단제의 갑작스러운 중단은 피해야 함."
    },
    "cat": {
      "status": 1,
      "evidence": "다른 국소 베타차단제가 건강한 고양이에서 심박수를 유의하게 감소시킨다는 보고가 있음. 심혈관계 및 호흡기계 이상 환자에서 주의 사용 필요."
    }
  },
  "storage_and_forms": {
    "storage": "냉장(2°C-8°C) 또는 실온(20°C-25°C) 보관. 습기와 직사광선을 피하고 동결 금지. 색 변화, 혼탁, 입자 발생 시 사용 금지.",
    "forms": [
