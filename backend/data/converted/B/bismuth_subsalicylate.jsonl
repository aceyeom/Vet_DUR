  "effects_and_mechanisms": {
    "common_mechanism": "소장에서 비스무트 카보네이트와 살리실레이트로 분해됨. 비스무트 성분은 위장관 보호, 항내독소, 약한 항균 작용을 가짐. 살리실레이트 성분은 프로스타글란딘 합성 억제를 통해 분비성 설사의 임상 증상을 감소시킴.",
    "common_extra_effects": [
      "변색(회흑색 또는 녹흑색 변)",
      "변비/분변 매복",
      "혀 변색",
      "살리실레이트 독성(고용량)",
      "신경독성(고용량 비스무트)",
      "잠재적 최기형성(살리실레이트)"
    ],
    "dog_mechanism": "개에서 급성 설사 및 헬리코박터 위염 치료에 사용됨. 위장관 보호 및 약한 항균 효과.",
    "dog_extra_effects": [
      "설사",
      "무기력",
      "구토",
      "운동실조",
      "쇠약",
      "헐떡임(과호흡)"
    ],
    "cat_mechanism": "고양이는 살리실레이트 대사 능력이 제한적이어서 독성 위험이 높음. 주의하여 사용하며 3일 이상 투여 금지.",
    "cat_extra_effects": [
      "설사",
      "무기력",
      "식욕부진",
      "살리실레이트 독성"
    ]
  },
  "species_notes": {
    "dog": "개에서 급성 설사 및 헬리코박터 위염 삼중 요법의 구성 요소로 사용됨. 고용량에서 신경독성(운동실조, 쇠약, 헐떡임) 가능. 변이 회흑색 또는 녹흑색으로 변할 수 있으며 흑색변과 혼동하지 않도록 주의. 비스무트는 방사선 불투과성이므로 위장관 방사선 검사를 방해할 수 있음.",
    "cat": "고양이는 살리실레이트에 민감하므로 매우 주의하여 사용해야 함. 3일 이상 투여하지 않도록 권고. 헬리코박터 위염 치료에 삼중 또는 사중 요법의 일부로 사용 가능. 살리실레이트 독성 징후(무기력, 식욕부진, 설사)를 면밀히 모니터링해야 함."
  },
